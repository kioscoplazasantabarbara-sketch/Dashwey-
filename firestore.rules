rules_version = '2';
// v1.3.979 — hardening: size limit + schema validation
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Firestore limite por doc = 1 MiB (1048576 bytes)
    // Dejamos margen de 24KB -> 1024000 bytes máx permitido en cliente
    function isValidSize() {
      return request.resource.size() < 1024000;
    }

    // Schema mínimo de /state/{uid}: al menos una clave reconocida
    function isValidState() {
      return request.resource.data.keys().hasAny(['user','productos','proveedores','ventas','historialPedidos','cuentas'])
        && (!('user' in request.resource.data) || request.resource.data.user is map);
    }

    // -- /state/{uid} -- doc principal Dashwey -----------------
    match /state/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidSize() && isValidState();
      allow delete: if isOwner(uid);
    }

    // -- /state/{uid}/fcmTokens/{deviceId} ---------------------
    match /state/{uid}/fcmTokens/{deviceId} {
      allow read: if isOwner(uid);
      allow delete: if isOwner(uid);
      allow create, update: if isOwner(uid) && request.resource.size() < 10000;
    }

    // -- /usuarios/{uid}/** -- contextos y datos ---------------
    match /usuarios/{uid}/{document=**} {
      allow read: if isOwner(uid);
      allow delete: if isOwner(uid);
      allow create, update: if isOwner(uid) && request.resource.size() < 1024000;
    }

    // -- Deny all else -----------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
