rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isMember() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isMember() && userRole() == 'admin';
    }

    function isStaff() {
      return isMember() && userRole() in ['admin', 'staff'];
    }

    // ── /users/{uid} ─────────────────────────────────────────────────
    // Cada usuario solo lee/escribe su propio doc
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && validUserCreate();
      allow update: if isOwner(uid) && validUserUpdate();
      allow delete: if false; // nunca borrar usuarios directamente
    }

    function validUserCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['email', 'role', 'createdAt'])
          && d.role in ['admin', 'staff', 'viewer']
          && d.email is string;
    }

    function validUserUpdate() {
      // No permitir cambio de role desde cliente
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // ── /state/{uid} ─────────────────────────────────────────────────
    // Doc principal de estado de Dashwey — solo el propietario
    match /state/{uid} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && validStateWrite();
      allow delete: if false;
    }

    function validStateWrite() {
      let d = request.resource.data;
      // Nunca escribir state vacío al Firebase (guard crítico)
      return d != null
          && !(d.keys().size() == 0)
          && !(d.get('productos', []).size() == 0
            && d.get('ventas', []).size() > 0);
    }

    // ── /ventas/{eventId} ────────────────────────────────────────────
    // Solo lectura desde cliente — escritura exclusiva via Cloud Functions (Admin SDK)
    match /ventas/{eventId} {
      allow read:  if isMember();
      allow write: if false; // solo Cloud Functions con Admin SDK
    }

    // ── /stock_log/{logId} ───────────────────────────────────────────
    match /stock_log/{logId} {
      allow read:  if isMember();
      allow write: if false; // solo Cloud Functions
    }

    // ── /productos/{prodId} ──────────────────────────────────────────
    // Admin puede crear/editar. Staff puede leer. Viewer solo lee.
    match /productos/{prodId} {
      allow read:   if isMember();
      allow create: if isAdmin() && validProducto();
      allow update: if isStaff() && validProductoUpdate();
      allow delete: if isAdmin();
    }

    function validProducto() {
      let d = request.resource.data;
      return d.keys().hasAll(['nombre', 'pvp', 'precioCompra', 'stockActual'])
          && d.nombre is string && d.nombre.size() > 0
          && d.pvp is number && d.pvp >= 0
          && d.precioCompra is number && d.precioCompra >= 0
          && d.stockActual is number;
    }

    function validProductoUpdate() {
      // No permitir cambio de id desde cliente
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id']);
    }

    // ── /config/{doc} ────────────────────────────────────────────────
    // Solo admin lee config (contiene loyverseToken referencia, etc.)
    match /config/{doc} {
      allow read:  if isAdmin();
      allow write: if false; // solo Cloud Functions / consola
    }

    // ── /sync_errors/{id} ────────────────────────────────────────────
    match /sync_errors/{id} {
      allow read:  if isAdmin();
      allow write: if false; // solo Cloud Functions
    }

    // ── Deny all else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
